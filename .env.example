# ── LLM Provider (LiteLLM) ────────────────────────────────────────
# LiteLLM routes to the correct provider based on model-name prefix.
#
# Provider examples:
#   DEFAULT_MODEL=openai/gpt-4o            → OpenAI
#   DEFAULT_MODEL=gemini/gemini-2.0-flash   → Google Gemini
#   DEFAULT_MODEL=ollama/llama3             → local Ollama
#   DEFAULT_MODEL=qwen3-vl                  → custom endpoint (set API_BASE)
#
# Fallback API key (used when no provider-specific key is set)
API_KEY=your-api-key

# Provider-specific API keys (read automatically by LiteLLM)
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key

# Base URL for local / custom OpenAI-compatible endpoints.
# Ignored when using cloud providers (openai/*, gemini/*).
API_BASE=http://localhost:8000/v1

# Default model for chat completions (LiteLLM model string)
DEFAULT_MODEL=qwen3-vl

# Embedding model (LiteLLM model string)
EMBEDDING_MODEL=text-embedding-3-small

# ── PostgreSQL (pgvector) ────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ldrs_v3
POSTGRES_USER=ldrs
POSTGRES_PASSWORD=ldrs_secret

# ── LangSmith Monitoring ────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=ldrs-v3

# ── File Watcher ─────────────────────────────────────────────────
# Comma-separated list of directories to watch for .md file changes
WATCH_DIRS=./docs
# Debounce interval in seconds
WATCH_DEBOUNCE=2.0

# ── Agent Settings ───────────────────────────────────────────────
# Max sections to populate in VFS per query
MAX_VFS_SECTIONS=15
# Character budget for retrieved context
MAX_CONTEXT_CHARS=15000
# Max agent loop iterations before forced synthesis
MAX_AGENT_ITERATIONS=10
